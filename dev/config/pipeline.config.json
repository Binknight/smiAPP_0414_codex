{
  "paths": {
    "repo_root": ".",
    "default_input_json": "scenario1.json",
    "task_template": "dev/config/task_template.txt",
    "base_app_root": "baseApp",
    "scenarios_root": "scenarios",
    "build_root": "build"
  },
  "git": {
    "remote_name": "origin",
    "remote_url": "ssh://git@ssh.github.com:443/Binknight/agentic-sim-app-starter.git",
    "default_base_branch": "main",
    "scenario_id_padding": 3,
    "fetch_all_known_branches": true,
    "app_types": {
      "generic": {
        "display_name": "通用类APP",
        "aliases": ["generic", "common", "main", "general"],
        "base_branch": "main-refact",
        "app_segment": "generic"
      },
      "explore": {
        "display_name": "内容类APP",
        "aliases": ["explore", "content"],
        "base_branch": "prod-explore-app",
        "app_segment": "explore"
      },
      "travel": {
        "display_name": "旅游类APP",
        "aliases": ["travel", "trip", "tour"],
        "base_branch": "prod-travel-app",
        "app_segment": "travel"
      }
    }
  },
  "agent": {
    "active": "opencode_cli",
    "definitions": {
      "codex_cli": {
        "display_name": "Codex CLI",
        "command": ["codex.cmd", "exec", "--yolo", "-"],
        "env": {},
        "task_via_stdin": true,
        "runtime_family": "codex",
        "supports_resume": false
      },
      "opencode_cli": {
        "display_name": "OpenCode CLI",
        "command": ["opencode.cmd", "run", "--dangerously-skip-permissions"],
        "env": {},
        "task_via_stdin": true,
        "runtime_family": "opencode",
        "supports_resume": false
      }
    }
  },
  "build": {
    "command": "powershell -ExecutionPolicy Bypass -File .\\build\\build.ps1",
    "readme_reference": "README.md"
  },
  "scheduler": {
    "poll_interval_seconds": 60,
    "max_cycles": 60,
    "success_values": ["success", "succeeded", "ok", "passed", "true"],
    "commit_message_template": "feat: automate {pipeline_key}"
  },
  "commit": {
    "shared_include_paths": []
  }
}
